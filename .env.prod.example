# Production environment variables template
# Copy to .env.prod and fill with real secrets on the server. Do NOT commit .env.prod with real secrets.

# Postgres
POSTGRES_DB=team_management
POSTGRES_USER=team_user
POSTGRES_PASSWORD=

# JWT - MUST be at least 32 characters
JWT_SECRET=

# Initial admin account used only for first start - change immediately
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=
INIT_ADMIN_DISPLAY_NAME=System Administrator

# Frontend origin (do NOT use '*')
FRONTEND_ALLOWED_ORIGINS=https://app.your-domain.com
FRONTEND_URL=https://app.your-domain.com

# Domain name used for TLS certificate
DOMAIN_NAME=api.your-domain.com

# Kafka (if using SASL/PLAINTEXT or external cluster)
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Optional: allow swagger public access on gateway (true/false). In production set to false.
GATEWAY_SWAGGER_PUBLIC=false

# DO NOT use weak or default passwords like 'admin123', 'team_password', or 'secret123'

